echo "🚀 Running pre-push checks..."

# Get commits that will be pushed (not yet on remote)
COMMITS=$(git log @{u}.. --oneline 2>/dev/null || git log HEAD~5.. --oneline)

if [ -z "$COMMITS" ]; then
  echo "✅ No new commits to push"
  exit 0
fi

echo "📦 Commits being pushed:"
echo "$COMMITS" | head -5
echo ""

# Collect changed top-level skills from commits that are about to be pushed.
SKILLS=$(git diff @{u}..HEAD --name-only --diff-filter=ACMR 2>/dev/null | grep -E '^skills/[^./][^/]*/' | cut -d/ -f2 | sort -u | tr '\n' ' ')

if [ -z "$SKILLS" ]; then
  echo "✅ No skill changes to validate"
  exit 0
fi

echo "📋 Validating skills: $SKILLS"
node scripts/skills/validate.mjs $SKILLS || exit 1

echo ""
echo "🧠 Semantic lint..."
node scripts/skills/lint-semantic.mjs --strict $SKILLS || exit 1
