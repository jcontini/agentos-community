# Pre-commit: structural YAML validation + security checks, scoped to staged skills
#
# Checks (blocking):
# - Structural validation — is the YAML frontmatter valid?
# - Security checks — no credential exposure patterns
#
# NOT checked here (belong in `npm run validate` / CI):
# - Entity references, test coverage, mapping validation, patterns

# Detect which skills were touched (any file under skills/X/)
SKILLS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^skills/[^/]+/' | cut -d/ -f2 | sort -u | tr '\n' ' ')

# Nothing to check
if [ -z "$SKILLS" ]; then
  exit 0
fi

ERRORS=0

# === Structural Validation ===
node tests/skills/scripts/validate.mjs --pre-commit $SKILLS || ERRORS=$((ERRORS + 1))

# === Security Checks ===
STAGED_READMES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^skills/[^/]+/readme\.md$' || true)

if [ -n "$STAGED_READMES" ]; then
  if echo "$STAGED_READMES" | xargs grep -l '\$AUTH_TOKEN\|\${AUTH_TOKEN}' 2>/dev/null; then
    echo "❌ \$AUTH_TOKEN found — use rest: or graphql: blocks instead"
    ERRORS=$((ERRORS + 1))
  fi

  if echo "$STAGED_READMES" | xargs grep -l 'curl.*[Aa]uthorization\|wget' 2>/dev/null; then
    echo "❌ curl/wget with auth — use AgentOS executors (rest:, graphql:, sql:)"
    ERRORS=$((ERRORS + 1))
  fi

  if echo "$STAGED_READMES" | xargs grep -l 'Bearer \$' 2>/dev/null; then
    echo "❌ Bearer token interpolation — AgentOS handles auth automatically"
    ERRORS=$((ERRORS + 1))
  fi
fi

if [ $ERRORS -gt 0 ]; then
  echo "❌ Fix $ERRORS error(s) before committing"
  exit 1
fi
