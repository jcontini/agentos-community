{
  "name": "agentos-integrations",
  "version": "0.1.0",
  "description": "Community skills for AgentOS",
  "type": "module",
  "scripts": {
    "test": "node scripts/skills/validate.mjs",
    "mcp:call": "node test-skills.cjs --call",
    "mcp:test": "node test-skills.cjs",
    "validate": "node scripts/skills/validate.mjs",
    "lint:semantic": "node scripts/skills/lint-semantic.mjs",
    "skills:extract-yaml": "node scripts/skills/extract-skill-yaml.mjs",
    "skills:bulk-plan": "python3 scripts/skills/bulk_extract_skill_yaml.py plan",
    "skills:bulk-apply": "python3 scripts/skills/bulk_extract_skill_yaml.py apply",
    "new-skill": "npx tsx scripts/skills/new-skill.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "husky": "^9.1.7",
    "typescript": "^5.3.0",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^4.3.5"
  },
  "optionalDependencies": {
    "playwright": "^1.58.2"
  }
}
