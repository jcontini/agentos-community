{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentos.dev/schemas/skill.schema.json",
  "title": "AgentOS Skill",
  "description": "Schema for AgentOS skill.yaml manifest",
  "type": "object",
  "required": ["id", "name", "description"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (lowercase, hyphenated)",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "description": {
      "type": "string",
      "description": "One-line description of what this skill does"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "URL to the service's website"
    },
    "color": {
      "type": "string",
      "description": "Brand color as hex (e.g., '#FF4500')",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "privacy_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the service's privacy policy"
    },
    "terms_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the service's terms of service"
    },
    "auth": {
      "oneOf": [
        { "const": "none", "description": "No authentication required" },
        { "$ref": "#/definitions/auth" }
      ]
    },
    "connections": {
      "type": "object",
      "description": "Named service dependencies. Each connection declares an external service with optional base_url and auth. Single-connection skills auto-infer; multi-connection skills use connection: on operations.",
      "additionalProperties": {
        "$ref": "#/definitions/connection"
      }
    },
    "api": {
      "$ref": "#/definitions/api"
    },
    "adapters": {
      "type": "object",
      "description": "Entity adapters that transform API data into universal entity format. Each key is an entity type.",
      "additionalProperties": {
        "$ref": "#/definitions/transformer"
      }
    },
    "operations": {
      "type": "object",
      "description": "Skill operations, including entity-returning reads/writes and inline-schema action tools",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/definitions/operation"
      }
    },
    "handles": {
      "type": "object",
      "description": "URL patterns this adapter handles for routing",
      "properties": {
        "urls": {
          "type": "array",
          "description": "URL patterns (e.g., 'youtube.com/*', 'github.com/*/issues/*')",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sources": {
      "$ref": "#/definitions/skillSources"
    },
    "agent": {
      "type": "object",
      "description": "Agent configuration — makes this skill an AI agent skill that runs an LLM loop instead of a single API call.",
      "required": ["intelligence", "system_prompt"],
      "properties": {
        "intelligence": {
          "type": "string",
          "description": "Intelligence reference: 'skill/model' (e.g., 'anthropic/claude-3-5-haiku-20241022')"
        },
        "system_prompt": {
          "type": "string",
          "description": "System prompt for the agent"
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Capabilities the agent can call. 'entity.operation' for runtime resolution, 'skill.entity.operation' for explicit binding."
        },
        "max_iterations": {
          "type": "integer",
          "description": "Maximum agent loop iterations (safety limit, default: 20)"
        },
        "temperature": {
          "type": "number",
          "description": "LLM sampling temperature (default: 0)"
        }
      },
      "additionalProperties": false
    },
    "accounts": {
      "type": "object",
      "description": "Multi-account discovery for provider skills (OAuth, browser profiles, …).",
      "required": ["list_via", "id_field"],
      "properties": {
        "list_via": {
          "type": "string",
          "description": "Operation that returns the account list (e.g. list_accounts)"
        },
        "id_field": {
          "type": "string",
          "description": "Field in each row that is the unique account identifier (e.g. email, name)"
        },
        "service_field": {
          "type": "string",
          "description": "Optional field naming which service an account belongs to"
        }
      },
      "additionalProperties": false
    },
    "provides": {
      "type": "array",
      "description": "Typed provides: OAuth/API credentials, cookies, or discoverable tools.",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["credentials"],
            "properties": {
              "credentials": {
                "type": "object",
                "properties": {
                  "oauth": { "$ref": "#/definitions/oauthProvides" },
                  "api_key": { "$ref": "#/definitions/apiKeyProvides" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["cookies"],
            "properties": {
              "cookies": {
                "type": "object",
                "required": ["via"],
                "properties": {
                  "via": { "type": "string" },
                  "domains": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "description": { "type": "string" },
                  "account_param": { "type": "string", "description": "Default: domain" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["tool", "via"],
            "properties": {
              "tool": { "type": "string", "description": "Tool name for capability matchmaking" },
              "via": { "type": "string", "description": "Operation implementing the tool" }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "dependency": {
      "type": "object",
      "description": "System dependency requirement",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Dependency name (e.g., 'yt-dlp', 'ffmpeg')"
        },
        "install": {
          "type": "object",
          "description": "Platform-specific install commands",
          "properties": {
            "macos": { "type": "string", "description": "macOS install command" },
            "linux": { "type": "string", "description": "Linux install command" },
            "windows": { "type": "string", "description": "Windows install command" }
          }
        }
      }
    },
    "oauthProvides": {
      "type": "object",
      "description": "OAuth tokens this skill can supply for oauth.service matchmaking",
      "required": ["service"],
      "properties": {
        "service": { "type": "string" },
        "via": { "type": "string" },
        "scopes": { "type": "array", "items": { "type": "string" } },
        "account_param": { "type": "string" }
      },
      "additionalProperties": false
    },
    "apiKeyProvides": {
      "type": "object",
      "required": ["service", "via"],
      "properties": {
        "service": { "type": "string" },
        "via": { "type": "string" }
      },
      "additionalProperties": false
    },
    "skillSources": {
      "type": "object",
      "description": "External sources for Content Security Policy",
      "properties": {
        "images": {
          "type": "array",
          "description": "Image sources (thumbnails, avatars) → CSP img-src",
          "items": { "type": "string" }
        },
        "api": {
          "type": "array",
          "description": "API endpoints → CSP connect-src",
          "items": { "type": "string" }
        },
        "scripts": {
          "type": "array",
          "description": "External scripts → CSP script-src (use sparingly)",
          "items": { "type": "string" }
        },
        "styles": {
          "type": "array",
          "description": "External stylesheets → CSP style-src",
          "items": { "type": "string" }
        },
        "fonts": {
          "type": "array",
          "description": "Web fonts → CSP font-src",
          "items": { "type": "string" }
        },
        "frames": {
          "type": "array",
          "description": "Embeddable frame sources (video players) → CSP frame-src",
          "items": { "type": "string" }
        },
        "image_headers": {
          "type": "object",
          "description": "Custom HTTP headers for the image proxy when fetching from this skill's image domains",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "transformer": {
      "type": "object",
      "description": "Flat adapter body. The adapter object itself is the mapping.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string", "description": "jaq expression (e.g., '.id', '.content', '5 - .priority')" },
          { "type": "null", "description": "Not provided by this API" },
          {
            "type": "object",
            "description": "Relationship ref: looks up existing entity and creates a typed relationship. Value can evaluate to scalar or array (creates one relationship per element). Direction inferred from relationship schemas.",
            "required": ["ref", "value"],
            "properties": {
              "ref": { "type": "string", "description": "Entity type to look up (e.g., 'journey', 'outcome')" },
              "value": { "type": "string", "description": "jaq expression for the lookup value (scalar or array)" },
              "rel": { "type": "string", "description": "Explicit relationship type (optional — inferred from schemas if unambiguous)" },
              "lookup": { "type": "string", "enum": ["name"], "description": "How to find the referenced entity: by name" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "description": "Typed reference: creates linked entity + relationship. The field name in the parent mapping IS the relationship type. Must have exactly one key (entity type) mapping to field definitions.",
            "minProperties": 1,
            "maxProperties": 1,
            "not": {
              "required": ["_rel"]
            },
            "additionalProperties": {
              "type": "object",
              "description": "Entity field mappings — jaq expressions for entity properties (e.g., { id: '.channel_id', name: '.channel' })",
              "additionalProperties": {
                "type": "string",
                "description": "jaq expression for entity field"
              }
            }
          }
        ]
      }
    },
    "operation": {
      "type": "object",
      "description": "Skill operation that returns either entity refs or an inline schema",
      "required": ["returns"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of what this operation does"
        },
        "returns": {
          "oneOf": [
            {
              "type": "string",
              "description": "Entity ref, primitive type name, or void (examples: 'webpage', 'webpage[]', 'boolean', 'void')",
              "pattern": "^([a-z_]+(\\[\\])?|void)$"
            },
            {
              "type": "object",
              "description": "Inline schema for action/local-control return shapes",
              "additionalProperties": {
                "oneOf": [
                  { "type": "string", "description": "Property type (string, boolean, integer, array, etc.)" },
                  {
                    "type": "object",
                    "description": "Detailed property definition",
                    "properties": {
                      "type": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                ]
              }
            }
          ]
        },
        "params": {
          "type": "object",
          "description": "Operation parameters",
          "additionalProperties": {
            "$ref": "#/definitions/paramDef"
          }
        },
        "response": {
          "$ref": "#/definitions/responseMapping",
          "description": "Operation-level response mapping (e.g. after a `steps` pipeline). Used when the executor omits `response`."
        },
        "rest": {
          "$ref": "#/definitions/restExecutor"
        },
        "graphql": {
          "$ref": "#/definitions/graphqlExecutor"
        },
        "sql": {
          "$ref": "#/definitions/sqlExecutor"
        },
        "command": {
          "$ref": "#/definitions/commandExecutor"
        },
        "swift": {
          "$ref": "#/definitions/swiftExecutor"
        },
        "csv": {
          "$ref": "#/definitions/csvExecutor"
        },
        "keychain": {
          "$ref": "#/definitions/keychainExecutor"
        },
        "crypto": {
          "$ref": "#/definitions/cryptoExecutor"
        },
        "steps": {
          "type": "array",
          "description": "Sequential pipeline steps (bare list). Pair with top-level `response` on the operation for transform/mapping.",
          "items": {
            "$ref": "#/definitions/step"
          }
        },
        "connection": {
          "oneOf": [
            {
              "type": "string",
              "description": "Single named connection (must match a key in skill.connections). Use \"none\" to skip auth."
            },
            {
              "type": "array",
              "description": "Agent-choosable connections; first is default. Caller sets params.connection to pick.",
              "items": { "type": "string" },
              "minItems": 1
            }
          ]
        },
        "python": {
          "oneOf": [
            { "type": "string", "description": "Python module path (relative to skill dir)" },
            { "type": "object", "description": "Python executor config", "properties": {
              "module": { "type": "string" },
              "function": { "type": "string" }
            }}
          ]
        },
        "applescript": {
          "type": "string",
          "description": "AppleScript code to execute"
        },
        "test": {
          "type": "object",
          "description": "Test configuration for this operation",
          "additionalProperties": true
        },
        "graph": {
          "type": "object",
          "description": "In-process graph entity query (by tag / filters)",
          "additionalProperties": true
        }
      }
    },
    "connection": {
      "type": "object",
      "description": "Named data source. HTTP connections use base_url; local database connections use sqlite; generic config uses vars. Auth fields declare how the runtime authenticates.",
      "properties": {
        "description": { "type": "string" },
        "base_url": { "type": "string", "description": "Base URL for HTTP services. Operations with relative URLs resolve against this." },
        "sqlite": {
          "oneOf": [
            { "type": "string", "description": "Path to SQLite database (supports ~ and globs)" },
            {
              "type": "object",
              "description": "Platform-specific database paths",
              "properties": {
                "macos": { "type": "string" },
                "windows": { "type": "string" },
                "linux": { "type": "string" }
              }
            }
          ],
          "description": "Local SQLite database path. The sql: executor resolves from this like rest: resolves from base_url."
        },
        "vars": {
          "type": "object",
          "description": "Non-secret config passed to script executors (file paths, versions, etc.). Supports ~ expansion.",
          "additionalProperties": { "type": "string" }
        },
        "header": { "type": "object", "additionalProperties": { "type": "string" } },
        "query": { "type": "object", "additionalProperties": { "type": "string" } },
        "body": { "type": "object", "additionalProperties": { "type": "string" } },
        "cookies": { "$ref": "#/definitions/auth/properties/cookies" },
        "oauth": { "$ref": "#/definitions/auth/properties/oauth" },
        "label": { "type": "string" },
        "help_url": { "type": "string", "format": "uri" },
        "optional": { "type": "boolean" },
        "account_params": {
          "type": "object",
          "description": "Account-level params for auto-injection (e.g., workspace_slug, team_id)",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "auth": {
      "type": "object",
      "description": "Auth injection. Template-based ({placeholder} syntax) for API keys, cookie-based auth via provider skills, or OAuth 2.0 via standalone config or provider matchmaking.",
      "properties": {
        "header": {
          "type": "object",
          "description": "Headers to inject. Values use {placeholder} for credential fields.",
          "additionalProperties": { "type": "string" }
        },
        "query": {
          "type": "object",
          "description": "Query params to inject. Values use {placeholder} for credential fields.",
          "additionalProperties": { "type": "string" }
        },
        "body": {
          "type": "object",
          "description": "Body params to inject. Values use {placeholder} for credential fields.",
          "additionalProperties": { "type": "string" }
        },
        "cookies": {
          "type": "object",
          "description": "Cookie-based auth for a domain. Prefer installed cookie provider skills that declare skill-level provides: cookies: { via: <operation> }. No user credential entry needed.",
          "required": ["domain"],
          "properties": {
            "domain": {
              "type": "string",
              "description": "Cookie domain to match (e.g., '.amazon.com', '.reddit.com')"
            },
            "names": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Specific cookie names to extract. If omitted, all cookies for the domain are used."
            },
            "session_duration": {
              "type": "string",
              "description": "Estimated session lifetime (e.g., '30d', '8h'). Used for credential expiry."
            },
            "login": {
              "type": "object",
              "description": "Multi-phase login recipe executed by the agent via Playwright. Each phase is a sequence of browser actions. Control returns to the agent between phases.",
              "properties": {
                "account_prompt": {
                  "type": "string",
                  "description": "Question to ask the user to determine the account (e.g., 'What email do you use?')"
                },
                "phases": {
                  "type": "array",
                  "description": "Ordered login phases. Agent executes each phase, filling in 'requires' values between phases.",
                  "items": {
                    "type": "object",
                    "required": ["name", "steps"],
                    "properties": {
                      "name": { "type": "string", "description": "Phase identifier" },
                      "description": { "type": "string", "description": "What this phase does" },
                      "requires": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Values the agent must provide before this phase (e.g., magic_link, mfa_code)"
                      },
                      "optional": {
                        "type": "boolean",
                        "description": "If true, agent can skip this phase (e.g., MFA not always required)"
                      },
                      "steps": {
                        "type": "array",
                        "description": "Playwright actions to execute",
                        "items": {
                          "type": "object",
                          "required": ["action"],
                          "properties": {
                            "action": { "type": "string", "description": "Playwright action: goto, fill, click, wait, evaluate, type, select" },
                            "url": { "type": "string" },
                            "selector": { "type": "string" },
                            "value": { "type": "string" },
                            "url_contains": { "type": "string", "description": "For wait action: wait until URL contains this string" },
                            "timeout": { "type": "integer" },
                            "script": { "type": "string" }
                          }
                        }
                      },
                      "returns_to_agent": {
                        "type": "string",
                        "description": "Message to the agent when this phase completes. Guides next steps."
                      }
                    }
                  }
                }
              }
            },
            "check": {
              "type": "object",
              "description": "Session liveness check — hit the URL with extracted cookies, pass if status matches",
              "properties": {
                "url": { "type": "string", "description": "URL to check" },
                "method": { "type": "string", "description": "HTTP method (default: GET)" },
                "expect_status": { "type": "integer", "description": "Expected HTTP status (default: 200)" }
              }
            }
          },
          "additionalProperties": false
        },
        "oauth": {
          "type": "object",
          "description": "OAuth 2.0 Authorization Code flow. When 'service' is set, auth is sourced from an installed provider skill (for example Mimestream for Google) — no client_id or secrets needed. For standalone OAuth, provide client_id, client_secret, auth_url, token_url.",
          "properties": {
            "service": {
              "type": "string",
              "description": "Service name for provider matchmaking (e.g., 'google'). If set, the resolver finds installed skills whose provides include credentials.oauth with the same service and calls the declared via operation (often credential_get). If several providers match, the agent should ask the user which provider to use."
            },
            "client_id": {
              "type": "string",
              "description": "OAuth client ID (not needed when using service matchmaking)"
            },
            "client_secret": {
              "type": "string",
              "description": "OAuth client secret (not needed when using service matchmaking)"
            },
            "auth_url": {
              "type": "string",
              "format": "uri",
              "description": "Authorization endpoint URL (not needed when using service matchmaking)"
            },
            "token_url": {
              "type": "string",
              "format": "uri",
              "description": "Token exchange endpoint URL (not needed when using service matchmaking)"
            },
            "scopes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "OAuth scopes to request"
            },
            "auth_params": {
              "type": "object",
              "description": "Extra parameters for the authorization URL (e.g., access_type, prompt)",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "label": {
          "type": "string",
          "description": "Human-readable label for the credential input"
        },
        "help_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to documentation on how to get credentials"
        },
        "optional": {
          "type": "boolean",
          "description": "If true, skill works without credentials (anonymous mode)"
        },
        "placeholder": {
          "type": "string",
          "description": "Example value shown in input field"
        },
        "help_text": {
          "type": "string",
          "description": "Additional help text for credential setup"
        },
        "account_params": {
          "type": "object",
          "description": "Additional account parameters beyond credentials",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "api": {
      "type": "object",
      "description": "API configuration",
      "properties": {
        "graphql_endpoint": {
          "type": "string",
          "format": "uri",
          "description": "GraphQL endpoint URL"
        }
      }
    },
    "paramDef": {
      "type": "object",
      "description": "Parameter definition",
      "properties": {
        "type": {
          "type": "string",
          "description": "Parameter type"
        },
        "required": {
          "type": "boolean",
          "description": "Whether parameter is required"
        },
        "default": {
          "description": "Default value if not provided"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "example": {
          "description": "Example value"
        },
        "enum": {
          "type": "array",
          "description": "Allowed values"
        }
      }
    },
    "restExecutor": {
      "type": "object",
      "description": "REST API call",
      "required": ["url"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "default": "GET"
        },
        "url": {
          "type": "string",
          "description": "Request URL (jaq expression, e.g. '\"https://api.example.com/\" + .params.id')"
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "query": {
          "type": "object",
          "description": "Query string parameters",
          "additionalProperties": { "type": "string" }
        },
        "body": {
          "description": "Request body (for POST/PUT/PATCH)"
        },
        "encoding": {
          "type": "string",
          "enum": ["json", "form"],
          "description": "Body encoding (default: json)"
        },
        "response": {
          "$ref": "#/definitions/responseMapping"
        }
      }
    },
    "graphqlExecutor": {
      "type": "object",
      "description": "GraphQL query/mutation",
      "required": ["query"],
      "properties": {
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "GraphQL endpoint (overrides api.graphql_endpoint)"
        },
        "query": {
          "type": "string",
          "description": "GraphQL query or mutation"
        },
        "variables": {
          "type": "object",
          "description": "Query variables (values are jaq expressions)"
        },
        "response": {
          "$ref": "#/definitions/responseMapping"
        }
      }
    },
    "sqlExecutor": {
      "type": "object",
      "description": "SQL query",
      "required": ["query"],
      "properties": {
        "query": {
          "type": "string",
          "description": "SQL query (jaq expression)"
        },
        "database": {
          "type": "string",
          "description": "SQLite path override (jaq expression). Use when the path is dynamic (e.g. apple-contacts) or for step-level SQL where operations do not carry connection:. Otherwise prefer the operation's connection sqlite:."
        },
        "response": {
          "$ref": "#/definitions/responseMapping"
        }
      }
    },
    "commandExecutor": {
      "type": "object",
      "description": "Shell command",
      "required": ["binary"],
      "properties": {
        "binary": {
          "type": "string",
          "description": "Binary to execute"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
