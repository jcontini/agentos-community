        },
        "iv": {
          "type": "string",
          "description": "For AES-128-CBC: hex-encoded 16-byte IV (supports template interpolation)"
        },
        "data": {
          "type": "string",
          "description": "For AES-128-CBC: hex-encoded ciphertext (supports template interpolation)"
        },
