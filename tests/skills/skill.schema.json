      "required": ["algorithm"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["pbkdf2", "aes-128-cbc"],
          "description": "Algorithm to use"
        },
        "password": {
          "type": "string",
          "description": "For PBKDF2: password input (supports template interpolation)"
