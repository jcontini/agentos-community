    "plistExecutor": {
      "type": "object",
      "description": "Parse NSKeyedArchiver binary plists and extract fields by $objects index. Input is a hex string from a keychain step.",
      "required": ["input", "extract"],
      "properties": {
        "input": {
          "type": "string",
          "description": "Hex-encoded binary plist (template-interpolated, typically {{step_id.value}} from a keychain step)"
